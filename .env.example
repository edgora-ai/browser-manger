# CloakLite local development environment example.
# Copy to .env if you need local overrides. Do not commit .env.

# Enable the real LLM E2E test suite explicitly.
# REAL_LLM=1
# REAL_LLM_API_KEY=replace-with-your-local-test-key
# REAL_LLM_API_URL=https://api.openai.com/v1/chat/completions
# REAL_LLM_MODEL=gpt-4o-mini

# Optional Electron / debugging flags can be added locally as needed.
# ELECTRON_ENABLE_LOGGING=1
